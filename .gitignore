# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- 가상환경 ---
.venv/
venv/
env/

# --- Django ---
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# --- 환경변수 (절대 커밋 금지) ---
.env
.env.*
!.env.example

# --- 미디어 / 정적 파일 ---
/media/
/staticfiles/

# --- 에디터 / OS ---
.idea/
# .vscode는 무시하되 settings.json만 공유 (${workspaceFolder} 기반이라 이식 가능)
# 주의: .gitignore는 줄 끝 주석 미지원 — 패턴 줄에 주석 붙이면 패턴이 깨짐
.vscode/*
!.vscode/settings.json
*.swp
.DS_Store

# --- 테스트 / 커버리지 ---
.pytest_cache/
.coverage
htmlcov/
